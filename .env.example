# ─────────────────────────────────────────────
# LocalBizSwarm — environment configuration
# Copy this file to .env and fill in your keys.
# Run `python run.py` to launch the onboarding
# wizard, which fills this file automatically.
# ─────────────────────────────────────────────


# ── Provider (one required) ───────────────────

# OpenAI — set this if using OpenAI as your primary provider.
OPENAI_API_KEY=

# Anthropic Claude — set this if using Anthropic as your primary provider.
ANTHROPIC_API_KEY=

# Google Gemini — set this if using Google as your primary provider.
GOOGLE_API_KEY=


# ── Model selection ───────────────────────────

# Override the default model for all agents (set automatically by onboarding).
# OpenAI example:   DEFAULT_MODEL=gpt-5.2
# Anthropic example: DEFAULT_MODEL=litellm/claude-sonnet-4-6
# Google example:   DEFAULT_MODEL=litellm/gemini/gemini-3-flash
DEFAULT_MODEL=


# ── Optional: Composio ───────────────────────

# Composio unlocks 10,000+ external integrations (Gmail, Slack, Google Calendar,
# HubSpot, GitHub, and more) for the General Agent.
# Get your key and user ID at https://composio.dev
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=


# ── Optional: Search ─────────────────────────

# Search API key — enables web search (WebSearchTool), Scholar search, and
# product search across agents.
# Get your key at https://www.searchapi.io
SEARCH_API_KEY=


# ── Optional: Images / Video ─────────────────────────

# Google AI / Gemini — used for image generation, editing, and composition
# (Gemini 2.5 Flash Image, Gemini 3 Pro Image) across Image Agent, Slides Agent,
# and Video Agent; also required for Veo video generation (Video Agent).
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Pexels — stock photo search used by Slides Agent (ImageSearch tool).
# Get your key at https://www.pexels.com/api
PEXELS_API_KEY=

# Pixabay — stock photo search used by Slides Agent (ImageSearch tool).
# Get your key at https://pixabay.com/api/docs
PIXABAY_API_KEY=

# Unsplash — stock photo search used by Slides Agent (ImageSearch tool).
# Get your key at https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=

# fal.ai — used for Seedance 1.5 Pro video generation, video editing (Video Agent),
# and background removal (Image Agent).
# Get your key at https://fal.ai/dashboard/keys
FAL_KEY=


# ── LocalBizSwarm — pipeline-specific keys ─────────────

# Google Places API (New) — required by Lead Hunter (GoogleMapsSearch tool).
# Enable "Places API (New)" on your GCP project and create a key.
# https://developers.google.com/maps/documentation/places/web-service/overview
GOOGLE_PLACES_API_KEY=

# Optional: override the model the Outreach Strategist uses inside
# GenerateOutreachPack. Defaults to gpt-4o-mini (OpenAI) or
# claude-sonnet-4-5 (Anthropic), whichever key is set.
OUTREACH_MODEL=

# Default channel routing per niche is set in the Outreach Sender
# instructions. To unlock real sending, connect these via Composio:
#   GMAIL, OUTLOOK   — email default
#   TWILIO           — SMS for trades
#   INSTAGRAM        — DMs for visual businesses
#   LINKEDIN         — B2B outreach
#   SLACK            — internal handoff notifications
# See https://composio.dev to connect each toolkit.


# ── Lovable.dev (browser-use harness) ─────────

# The Mockup Builder ships a real, hosted preview by driving lovable.dev with
# browser-use (lovable.dev has no public API or MCP yet). Set both to enable.
LOVABLE_EMAIL=
LOVABLE_PASSWORD=

# Optional: model used by browser-use to drive the Lovable UI.
# Default: gpt-4o.
BROWSER_USE_MODEL=


# ── Higgsfield (DoP image-to-video) ───────────

# The Demo Video Agent renders the 10s 9:16 cinematic walkthrough on
# platform.higgsfield.ai using the official Python SDK.
# Two ways to authenticate:
#   1) HF_KEY=KEY_ID:KEY_SECRET   (single line)
#   2) HF_API_KEY=...  +  HF_API_SECRET=...
# Get credentials from https://cloud.higgsfield.ai → API.
HF_KEY=
HF_API_KEY=
HF_API_SECRET=

# Alternatively, you can connect the official Higgsfield MCP server
# (https://mcp.higgsfield.ai/mcp) to your MCP-aware client (Claude Code,
# Cursor) and the Demo Video Agent will see those tools too. The above
# keys are only needed if you want the swarm to call Higgsfield directly
# without an external MCP client.
